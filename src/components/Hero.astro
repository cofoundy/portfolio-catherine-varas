---
import { siteConfig } from "../config";
---

<section id="hero" class="relative min-h-[85vh] flex items-center justify-center overflow-hidden pt-24">
  <!-- Ambient gradient blobs -->
  <div class="absolute inset-0 overflow-hidden">
    <div id="blob-a" class="absolute w-[500px] h-[500px] rounded-full opacity-20 blur-[120px] bg-blue-600"></div>
    <div id="blob-b" class="absolute w-[400px] h-[400px] rounded-full opacity-15 blur-[120px] bg-violet-600"></div>
    <div id="blob-c" class="absolute w-[350px] h-[350px] rounded-full opacity-10 blur-[100px] bg-pink-600"></div>
  </div>

  <!-- Gradient overlay for depth -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#030712] z-[1]"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 glass rounded-full mb-6 animate-fade-up">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
      <span class="text-xs md:text-sm text-slate-300 font-mono tracking-wider uppercase">Data & AI Engineer</span>
    </div>

    <!-- Name -->
    <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl xl:text-9xl font-bold hero-name-shimmer mb-2 animate-fade-up leading-tight">
      {siteConfig.name}
    </h1>

    <!-- Decorative separator -->
    <div class="w-24 md:w-32 h-1 mx-auto mb-6 rounded-full bg-gradient-to-r from-blue-500 via-violet-500 to-pink-500 animate-fade-up delay-1"></div>

    <!-- Rotating tagline -->
    <div class="h-8 md:h-10 mb-6 animate-fade-up delay-1">
      <p id="tagline" class="text-lg md:text-2xl text-blue-400 font-mono">
        {siteConfig.taglines[0]}
      </p>
    </div>

    <!-- Description -->
    <p class="text-sm md:text-base text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-up delay-2">
      {siteConfig.description}
    </p>

    <!-- Stats -->
    <div class="flex flex-wrap justify-center gap-6 md:gap-10 mb-10 animate-fade-up delay-3">
      {siteConfig.stats.map((stat) => (
        <div class="text-center">
          <div class="text-2xl md:text-3xl font-bold gradient-text-blue">{stat.value}</div>
          <div class="text-xs md:text-sm text-slate-500 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Social + CTA -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up delay-4">
      <a
        href="#projects"
        class="px-6 py-3 bg-gradient-to-r from-blue-600 to-violet-600 rounded-full text-white text-sm font-medium hover:shadow-lg hover:shadow-blue-500/25 transition-all duration-300 hover:scale-105"
      >
        View My Work
      </a>
      <div class="flex items-center gap-3">
        <a href={siteConfig.social.github} target="_blank" rel="noopener" class="p-2.5 glass rounded-full hover:bg-white/10 transition-all duration-200 group" aria-label="GitHub">
          <svg class="w-5 h-5 text-slate-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener" class="p-2.5 glass rounded-full hover:bg-white/10 transition-all duration-200 group" aria-label="LinkedIn">
          <svg class="w-5 h-5 text-slate-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={`mailto:${siteConfig.social.email}`} class="p-2.5 glass rounded-full hover:bg-white/10 transition-all duration-200 group" aria-label="Email">
          <svg class="w-5 h-5 text-slate-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-fade-in delay-6">
      <div class="animate-float">
        <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const blobs = [
      { el: document.getElementById('blob-a')!, cx: 0.3, cy: 0.3, rx: 0.2, ry: 0.15, speed: 0.0004 },
      { el: document.getElementById('blob-b')!, cx: 0.7, cy: 0.5, rx: 0.25, ry: 0.2, speed: 0.0003 },
      { el: document.getElementById('blob-c')!, cx: 0.5, cy: 0.7, rx: 0.15, ry: 0.25, speed: 0.00035 },
    ];

    let t = 0;
    function animate() {
      t++;
      const w = window.innerWidth;
      const h = window.innerHeight;
      for (const b of blobs) {
        const x = b.cx * w + Math.sin(t * b.speed) * b.rx * w;
        const y = b.cy * h + Math.cos(t * b.speed * 1.3) * b.ry * h;
        b.el.style.left = x - b.el.offsetWidth / 2 + 'px';
        b.el.style.top = y - b.el.offsetHeight / 2 + 'px';
      }
      requestAnimationFrame(animate);
    }
    animate();

    const taglines = [
      "Building Data Platforms",
      "Migrating Legacy to Cloud",
      "Enabling AI Integration",
      "Engineering Scalable Pipelines",
    ];
    let taglineIdx = 0;
    const taglineEl = document.getElementById('tagline');

    setInterval(() => {
      taglineIdx = (taglineIdx + 1) % taglines.length;
      if (taglineEl) {
        taglineEl.style.opacity = '0';
        taglineEl.style.transform = 'translateY(10px)';
        setTimeout(() => {
          taglineEl.textContent = taglines[taglineIdx];
          taglineEl.style.opacity = '1';
          taglineEl.style.transform = 'translateY(0)';
        }, 300);
      }
    }, 3000);

    if (taglineEl) {
      taglineEl.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
    }
  })();
</script>
