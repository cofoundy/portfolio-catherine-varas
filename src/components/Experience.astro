---
import { siteConfig } from "../config";
import BrandIcon from "./BrandIcon.astro";
import { getIconInfo } from "../utils/icons";
---

<section id="experience" class="relative py-24 md:py-32 bg-[#0a0f1a]">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Section header -->
    <div class="reveal mb-16">
      <p class="text-sm font-mono text-blue-400 mb-2">// experience</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Career Timeline</h2>
      <div class="shimmer-bar w-24 mt-4"></div>
    </div>

    <!-- Timeline -->
    <div class="relative pl-10 md:pl-12">
      <!-- Vertical line -->
      <div class="timeline-line"></div>

      {siteConfig.experience.map((exp, i) => (
        <div class={`reveal stagger-${Math.min(i + 1, 6)} relative mb-10 last:mb-0`}>
          <!-- Dot -->
          <div class={`timeline-dot ${exp.featured ? 'timeline-dot-featured' : ''}`}></div>

          <!-- Card -->
          <div class={`glass rounded-xl p-5 md:p-6 card-3d ${exp.featured ? 'border-l-2 border-violet-500' : ''}`}>
            <!-- Header -->
            <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
              <div>
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                  {getIconInfo(exp.company).isLogotype ? (
                    /* Logotype (wide text logo like "BBVA") — logo REPLACES text */
                    <BrandIcon name={exp.company} size={24} dark />
                  ) : getIconInfo(exp.company).file ? (
                    /* Isotipo (square icon) — logo + text */
                    <Fragment>
                      <BrandIcon name={exp.company} size={22} dark />
                      {exp.company}
                    </Fragment>
                  ) : (
                    /* No icon — just text */
                    <Fragment>{exp.company}</Fragment>
                  )}
                  {exp.featured && <span class="ml-1 text-xs px-2 py-0.5 rounded-full bg-violet-500/20 text-violet-300 font-mono">KEY ROLE</span>}
                </h3>
                {exp.subtitle && <p class="text-xs text-slate-400">{exp.subtitle}</p>}
                <p class="text-sm text-blue-400">{exp.title}</p>
              </div>
              <div class="text-right">
                <p class="text-xs text-slate-400 font-mono">{exp.dateRange}</p>
                <p class="text-xs text-slate-400">{exp.location}</p>
              </div>
            </div>

            <!-- Highlights -->
            <ul class="space-y-2 mb-4">
              {exp.highlights.map((h) => (
                <li class="text-sm text-slate-400 flex items-start gap-2">
                  <span class="text-blue-500 mt-1 shrink-0">▹</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5">
              {exp.tags.map((tag) => (
                <span class="px-2 py-0.5 text-[10px] font-mono rounded bg-blue-500/10 text-blue-300 border border-blue-500/20">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
