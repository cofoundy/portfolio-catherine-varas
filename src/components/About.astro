---
import { siteConfig } from "../config";
import BrandIcon from "./BrandIcon.astro";

// No hardcoded map needed — BrandIcon auto-discovers from public/icons/
const skillCategories = [
  { label: "Engineering", items: siteConfig.skills.engineering, color: "blue" },
  { label: "Cloud", items: siteConfig.skills.cloud, color: "violet" },
  { label: "AI & ML", items: siteConfig.skills.ai, color: "pink" },
  { label: "Tools", items: siteConfig.skills.tools, color: "cyan" },
  { label: "Databases", items: siteConfig.skills.databases, color: "emerald" },
];
---

<section id="about" class="relative py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-16">
      <p class="text-sm font-mono text-blue-400 mb-2">// about</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">The Journey</h2>
      <div class="shimmer-bar w-24 mt-4"></div>
    </div>

    <!-- Two columns: photo + narrative -->
    <div class="grid md:grid-cols-2 gap-12 items-start mb-20">
      <div class="reveal stagger-1 flex justify-center md:justify-start">
        <div class="relative">
          <div class="w-72 md:w-96 rounded-2xl overflow-hidden gradient-border">
            <img
              src="/profile.jpg"
              alt={siteConfig.name}
              class="w-full h-auto"
              loading="lazy"
            />
          </div>
          <div class="absolute -bottom-3 -right-3 glass rounded-full px-4 py-2 text-xs font-mono text-blue-300">
            Lima 🇵🇪 → Sydney 🇦🇺
          </div>
        </div>
      </div>

      <div class="reveal stagger-2 space-y-5">
        <p class="text-slate-300 leading-relaxed">{siteConfig.about.intro}</p>
        <p class="text-slate-400 leading-relaxed">{siteConfig.about.current}</p>
        <div class="glass rounded-xl p-4 border-l-2 border-blue-500">
          <p class="text-sm text-slate-300 italic">"{siteConfig.about.superpower}"</p>
        </div>
      </div>
    </div>

    <!-- Skills grid with icons -->
    <div class="reveal">
      <h3 class="text-xl font-bold text-white mb-8">Tech Stack</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {skillCategories.map((cat, i) => (
          <div class={`reveal stagger-${i + 1} glass rounded-xl p-5`}>
            <h4 class="text-sm font-mono text-blue-400 mb-3">{cat.label}</h4>
            <div class="flex flex-wrap gap-2">
              {cat.items.map((skill) => (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs rounded-full bg-white/5 text-slate-300 border border-white/10 hover:border-blue-500/50 hover:text-white transition-all duration-200">
                  <BrandIcon name={skill} size={12} />
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
