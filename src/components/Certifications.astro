---
import { siteConfig } from "../config";
import BrandIcon from "./BrandIcon.astro";

// No hardcoded map — BrandIcon auto-discovers from public/icons/
---

<section id="certifications" class="relative py-24 md:py-32 bg-[#0a0f1a]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal mb-16">
      <p class="text-sm font-mono text-blue-400 mb-2">// certifications</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Credentials</h2>
      <div class="shimmer-bar w-24 mt-4"></div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
      {siteConfig.certifications.map((cert, i) => (
        <div class={`reveal stagger-${Math.min(i + 1, 6)} glass rounded-xl p-5 card-3d group hover:border-blue-500/30 text-center`}>
          <!-- Provider icon -->
          <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-gradient-to-br from-white/5 to-white/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            <BrandIcon name={cert.provider} size={28} />
          </div>

          <h3 class="text-sm md:text-base font-semibold text-white mb-1">{cert.name}</h3>

          {cert.code && (
            <p class="text-[10px] font-mono text-blue-400 mb-2">{cert.code}</p>
          )}

          <p class="text-xs text-slate-500">{cert.provider}</p>
        </div>
      ))}
    </div>
  </div>
</section>
