const key = name.toLowerCase();
const isFile = fileIcons.has(key);
const inline = inlineIcons[key];
const fillColor = color || (inline ? `#${inline.hex}` : "currentColor");
---

{isFile ? (
  <img
    src={`/icons/${key}.svg`}
    alt={name}
    width={size}
    height={size}
    class={className}
    loading="lazy"
    style="display:inline-block;vertical-align:middle;"
  />
) : inline ? (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill={fillColor}
    class={className}
    role="img"
    aria-label={name}
  >
    <path d={inline.path} />
  </svg>
) : (
  <span class={`inline-flex items-center justify-center rounded bg-white/10 text-[10px] font-mono ${className}`} style={`width:${size}px;height:${size}px;`}>
    {name.slice(0, 2).toUpperCase()}
  </span>
)}
