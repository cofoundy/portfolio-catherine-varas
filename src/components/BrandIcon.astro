---
/**
 * BrandIcon — File-based icon component
 * All icons are real SVGs from devicon/gilbarbara/simple-icons
 * Downloaded to public/icons/ — zero CDN dependency, zero fabrication
 *
 * Source: devicon (github.com/devicons/devicon) for most
 *         gilbarbara/logos for Snowflake
 *         simple-icons for Databricks
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 20, class: className = "" } = Astro.props;

// Map display names → file names in public/icons/
const iconFiles: Record<string, string> = {
  // Engineering
  java: "java",
  python: "python",
  apachespark: "apachespark",
  databricks: "databricks",
  // Cloud
  azure: "azure",
  aws: "aws",
  docker: "docker",
  kubernetes: "kubernetes",
  // Databases
  postgresql: "postgresql",
  mysql: "mysql",
  oracle: "oracle",
  snowflake: "snowflake",
  // Tools
  git: "git",
  streamlit: "streamlit",
  graphql: "graphql",
  // AI
  scikitlearn: "scikitlearn",
  // Providers
  microsoft: "microsoft",
};

const key = name.toLowerCase();
const file = iconFiles[key];
---

{file ? (
  <img
    src={`/icons/${file}.svg`}
    alt={name}
    width={size}
    height={size}
    class:list={[className]}
    loading="lazy"
    style="display:inline-block;vertical-align:middle;"
  />
) : (
  <span
    class:list={["inline-flex items-center justify-center rounded bg-white/10 text-[10px] font-mono text-slate-400", className]}
    style={`width:${size}px;height:${size}px;`}
  >
    {name.slice(0, 2).toUpperCase()}
  </span>
)}
